<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/colorBackground"
		android:orientation="vertical"
		>

	<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/topAppBar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="@color/colorPrimaryVariant"
			app:title="@string/sdk_ui_title"
			app:titleTextColor="@color/colorOnSurface"
			/>

	<!-- Content inside a ScrollView -->
	<ScrollView
			android:layout_width="match_parent"
			android:layout_height="0dp"
			android:layout_weight="1"
			app:layout_behavior="@string/appbar_scrolling_view_behavior"
			>

		<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:padding="@dimen/margin_2x"
				>
			<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/colorOnSurfaceVariant"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:paddingHorizontal="@dimen/margin_2x"
					android:paddingVertical="@dimen/margin_0x5"
					>

				<com.google.android.material.textview.MaterialTextView
						android:id="@+id/textDarkModeLabel"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:textColor="@color/colorOnSurface"
						style="@style/TextAppearance.MaterialComponents.Subtitle1"
						/>

				<com.google.android.material.switchmaterial.SwitchMaterial
						android:id="@+id/switchDarkMode"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						/>
			</LinearLayout>

			<com.google.android.material.textview.MaterialTextView
					android:id="@+id/textUIComponents"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/margin_2x"
					android:padding="@dimen/margin_2x"
					android:text="@string/ui_components_title"
					android:textColor="@color/colorOnBackground"
					style="@style/TextAppearance.MaterialComponents.Subtitle2"
					/>

			<LinearLayout
					android:id="@+id/rowCardForm"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/colorOnSurfaceVariant"
					android:clickable="true"
					android:focusable="true"
					android:foreground="?attr/selectableItemBackground"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:padding="@dimen/margin_2x"
					>

				<com.google.android.material.textview.MaterialTextView
						android:id="@+id/textCardForm"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="@string/card_form_title"
						android:textColor="@color/colorOnSurface"
						style="@style/TextAppearance.MaterialComponents.Subtitle1"
						/>

				<ImageView
						android:id="@+id/iconChevronCard"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="@dimen/margin_2x"
						android:importantForAccessibility="no"
						app:tint="@color/colorOnSurface"
						android:src="@drawable/arrow_right"
						/>
			</LinearLayout>

			<!-- Google Pay Button Row -->
			<LinearLayout
					android:id="@+id/rowGooglePay"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/colorOnSurfaceVariant"
					android:clickable="true"
					android:focusable="true"
					android:foreground="?attr/selectableItemBackground"
					android:orientation="horizontal"
					android:padding="@dimen/margin_2x"
					>

				<com.google.android.material.textview.MaterialTextView
						android:id="@+id/textGooglePayButton"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:textColor="@color/colorOnSurface"
						android:text="@string/google_pay_button_title"
						style="@style/TextAppearance.MaterialComponents.Subtitle1"
						/>

				<ImageView
						android:id="@+id/iconChevronGooglePay"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						app:tint="@color/colorOnSurface"
						android:importantForAccessibility="no"
						android:src="@drawable/arrow_right"
						/>
			</LinearLayout>

		</LinearLayout>
	</ScrollView>
	<com.google.android.material.textview.MaterialTextView
			android:id="@+id/tvAppData"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:textColor="@color/colorOnSurface"
			android:layout_margin="@dimen/margin_2x"
			style="@style/TextAppearance.MaterialComponents.Subtitle1"
			/>
</LinearLayout>
