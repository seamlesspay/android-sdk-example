<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    >

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimaryVariant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/colorOnSurface"
        app:title="@string/diagnostic_info_title"
        app:titleTextColor="@color/colorOnSurface"
        />
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btnCopy"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="@dimen/margin_2x"
        app:layout_constraintTop_toBottomOf="@+id/topAppBar"
        >
        <LinearLayout
            android:id="@+id/llInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:layout_margin="@dimen/margin_3x"
            android:orientation="vertical"
            android:background="@color/colorOnSurfaceVariant"
            android:padding="@dimen/margin_2x"
            />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCopy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_3x"
        android:backgroundTint="@android:color/transparent"
        android:text="@string/copy_info_title"
        android:textColor="@color/colorPrimary"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_copy"
        app:iconGravity="textStart"
        app:iconTint="@color/colorPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/colorOnSurface"
        app:strokeWidth="1dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>
