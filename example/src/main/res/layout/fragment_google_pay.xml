<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/colorBackground"
		android:orientation="vertical"
		>

	<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/topAppBar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="@color/colorPrimaryVariant"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:navigationIcon="@drawable/ic_arrow_back"
			app:navigationIconTint="@color/colorOnSurface"
			app:title="@string/google_pay_button_title"
			app:titleTextColor="@color/colorOnSurface"
			/>

	<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/tiAmount"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginHorizontal="@dimen/margin_2x"
			android:layout_marginTop="@dimen/margin_2x"
			android:hint="@string/amount_hint"
			app:boxBackgroundMode="outline"
			app:boxStrokeColor="@color/outlined_box_stroke_color"
			app:boxStrokeWidthFocused="1dp"
			app:hintTextColor="@color/colorOnSurface"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/topAppBar"
			app:prefixText="$"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
			>

		<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/etAmount"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:inputType="textPersonName"
				android:textColor="@color/colorOnSurface"
				/>
	</com.google.android.material.textfield.TextInputLayout>
	<FrameLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="@dimen/margin_5x"
			android:layout_marginHorizontal="@dimen/margin_3x"
			android:animateLayoutChanges="true"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			>
		<com.google.android.gms.wallet.button.PayButton
				android:id="@+id/payButton"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:visibility="gone"
				/>
		<com.google.android.material.progressindicator.LinearProgressIndicator
				android:id="@+id/piGooglePay"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:indeterminate="true"
				/>
		<TextView
				android:id="@+id/tvPayUnavailable"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center"
				android:text="@string/google_pay_unavailable"
				android:visibility="gone"
				/>
	</FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
