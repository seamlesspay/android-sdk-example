<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/colorBackground"
		android:orientation="vertical"
		>

	<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/topAppBar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:background="@color/colorPrimaryVariant"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:menu="@menu/toolbar_menu"
			app:navigationIcon="@drawable/ic_arrow_back"
			app:navigationIconTint="@color/colorOnSurface"
			app:title="@string/card_form_title"
			app:titleTextColor="@color/colorOnSurface"
			/>
	<ScrollView
			android:id="@+id/scrollView"
			android:layout_width="match_parent"
			android:layout_height="0dp"
			app:layout_constraintBottom_toTopOf="@+id/btnCopy"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			android:layout_marginBottom="@dimen/margin_2x"
			app:layout_constraintTop_toBottomOf="@+id/topAppBar"
			>
		<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:animateLayoutChanges="true"
				android:orientation="vertical"
				android:padding="@dimen/margin_3x"
				>
			<TextView
					android:id="@+id/tvError"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/error"
					android:drawablePadding="@dimen/margin_1x"
					android:gravity="center_vertical"
					android:padding="@dimen/margin_2x"
					android:text="@string/error_title"
					android:textColor="@color/white"
					android:visibility="gone"
					app:drawableStartCompat="@drawable/ic_error"
					style="@style/TextAppearance.MaterialComponents.Subtitle2"
					/>
			<TextView
					android:id="@+id/tvSuccess"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/success"
					android:drawablePadding="@dimen/margin_1x"
					android:gravity="center_vertical"
					android:padding="@dimen/margin_2x"
					android:text="@string/success_title"
					android:textColor="@color/white"
					android:visibility="gone"
					app:drawableStartCompat="@drawable/ic_success"
					style="@style/TextAppearance.MaterialComponents.Subtitle2"
					/>
			<com.google.android.material.textview.MaterialTextView
					android:id="@+id/textUIComponents"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/margin_3x"
					android:padding="@dimen/margin_2x"
					android:text="@string/response_code_title"
					android:textColor="@color/colorOnBackground"
					style="@style/TextAppearance.MaterialComponents.Subtitle2"
					/>
			<com.google.android.material.textview.MaterialTextView
					android:id="@+id/tvContent"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@color/colorOnSurfaceVariant"
					android:gravity="center_vertical"
					android:padding="@dimen/margin_2x5"
					android:textColor="@color/colorOnSurface"
					style="@style/TextAppearance.MaterialComponents.Body1"
					/>
		</LinearLayout>
	</ScrollView>

	<com.google.android.material.button.MaterialButton
			android:id="@+id/btnCopy"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_margin="@dimen/margin_3x"
			android:backgroundTint="@android:color/transparent"
			android:text="@string/copy_response_title"
			android:textColor="@color/colorPrimary"
			app:cornerRadius="24dp"
			app:icon="@drawable/ic_copy"
			app:iconGravity="textStart"
			app:iconTint="@color/colorPrimary"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:strokeColor="@color/colorOnSurface"
			app:strokeWidth="1dp"
			/>
</androidx.constraintlayout.widget.ConstraintLayout>
